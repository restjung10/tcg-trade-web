# Supabase 프로젝트 설정 (Settings > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 사이트 URL (OAuth redirect 계산용, 로컬 개발 시 http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Phase 3에서 사용 (AI 생성 이미지 검증)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# Phase 5에서 사용 (계좌번호 암호화, 32바이트를 base64로 인코딩한 값)
# 생성 예: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BANK_ACCOUNT_ENCRYPTION_KEY=

# 채팅 웹 푸시 알림용 VAPID 키 (생성: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:example@example.com
